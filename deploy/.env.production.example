# =============================================================
# Template de variáveis de ambiente para produção (Docker)
# Copie para .env.prod na raiz do projeto e preencha os valores
# NÃO commite este arquivo com valores reais
# =============================================================

# Domínio público (usado pelo nginx e certbot)
DOMAIN=clinica.exemplo.com.br

# Django
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<gerar-chave-aleatoria>
DEBUG=False
ALLOWED_HOSTS=clinica.exemplo.com.br,www.clinica.exemplo.com.br

# Banco de dados PostgreSQL (o DB_HOST é sempre "db" no Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=corpoclinico
DB_USER=corpoclinico
DB_PASSWORD=<senha-forte-aleatoria>
DB_HOST=db
DB_PORT=5432

# CORS e CSRF
CORS_ALLOWED_ORIGINS=https://clinica.exemplo.com.br,https://www.clinica.exemplo.com.br
CSRF_TRUSTED_ORIGINS=https://clinica.exemplo.com.br,https://www.clinica.exemplo.com.br

# URL do frontend (usada nos links de e-mail)
FRONTEND_URL=https://clinica.exemplo.com.br

# E-mail (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@clinica.exemplo.com.br
EMAIL_HOST_PASSWORD=<app-password-do-gmail>
DEFAULT_FROM_EMAIL=Corpo Clínico <noreply@clinica.exemplo.com.br>
